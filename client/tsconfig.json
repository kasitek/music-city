{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@music-city/shared": [
        "../packages/shared/dist/index.d.ts"
      ],
      "next": [
        "./src/compat/next.ts"
      ],
      "next/link": [
        "./src/compat/next-link.tsx"
      ],
      "next/navigation": [
        "./src/compat/next-navigation.ts"
      ],
      "next/image": [
        "./src/compat/next-image.tsx"
      ],
      "next/font/google": [
        "./src/compat/next-font-google.ts"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
